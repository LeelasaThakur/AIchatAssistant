# ============================================================
# AI Chat Assistant — Environment Variables
# ============================================================
# Copy this file to .env and fill in the values.
# Never commit .env to version control.
# ============================================================

# ---- REQUIRED ----

# Flask session signing key. Generate with: python -c "import secrets; print(secrets.token_hex(32))"
SECRET_KEY=change-me-to-a-random-64-char-hex-string

# Groq API key. Get one at https://console.groq.com/keys
GROQ_API_KEY=gsk_your_key_here

# ---- OPTIONAL ----

# Groq model (default: llama-3.3-70b-versatile)
# GROQ_MODEL=llama-3.3-70b-versatile

# Database URL. Leave blank for local SQLite.
# For production, use PostgreSQL: postgresql+psycopg2://user:pass@host:5432/dbname
# DATABASE_URL=

# Set to true when serving over HTTPS (always true in production)
SESSION_COOKIE_SECURE=False

# Force production mode locally (optional)
# FLASK_ENV=production
